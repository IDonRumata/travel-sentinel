# === Travel Sentinel - Environment Variables ===
# Copy to .env and fill in real values. NEVER commit .env!

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=travel_sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Claude API (used by n8n AI Agent node)
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Brave Search API (OPTIONAL for visa checks)
# If not set, uses local KNOWN_VISA_FREE_BY table (30+ countries, zero cost)
# For unknown countries, will return UNKNOWN status instead of querying web
BRAVE_SEARCH_API_KEY=

# Aviasales API
AVIASALES_TOKEN=CHANGE_ME

# Telegram Bot (for alerts)
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# App settings
LOG_LEVEL=INFO
SCRAPE_INTERVAL_MINUTES=60
PRICE_DROP_THRESHOLD_PERCENT=10
MAX_PRICE_PER_PERSON_USD=400
ADULTS=2
PASSPORT_TYPE=BY
